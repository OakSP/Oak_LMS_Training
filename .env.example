# Oak LMS — Environment Variables
# Copy to .env.local and fill in values

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Connection pooling URL (used at runtime)
DATABASE_URL="postgresql://user:pass@host.neon.tech/dbname?sslmode=require&pgbouncer=true"
# Direct URL (used by prisma migrate/push)
DIRECT_URL="postgresql://user:pass@host.neon.tech/dbname?sslmode=require"

# ── NextAuth v5 ────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# ── OAuth Providers ────────────────────────────────────────────────────────────
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Mux (Video) ────────────────────────────────────────────────────────────────
MUX_TOKEN_ID="..."
MUX_TOKEN_SECRET="..."

# ── Cloudflare R2 (File Storage) ───────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID="..."
CLOUDFLARE_R2_ACCESS_KEY_ID="..."
CLOUDFLARE_R2_SECRET_ACCESS_KEY="..."
CLOUDFLARE_R2_BUCKET_NAME="oak-lms"
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub.r2.dev/oak-lms"

# ── Resend (Transactional Email) ───────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
