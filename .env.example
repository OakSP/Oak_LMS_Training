# ============================================================
# Oak LMS — Environment Variables
# Copy to .env.local for local development
# Set all variables in Vercel Dashboard for production
# ============================================================

# ── App URL ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication (NextAuth v5) ─────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your-secret-min-32-chars
AUTH_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# Local:      postgresql://postgres:postgres123@localhost:5432/oak_lms
# Neon prod:  postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/oak_lms?sslmode=require
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/oak_lms
DIRECT_URL=postgresql://postgres:postgres123@localhost:5432/oak_lms

# ── OAuth (optional) ─────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Payment — Stripe (optional) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── File Storage — Cloudflare R2 (optional) ──────────────────
CLOUDFLARE_R2_BUCKET=lms-storage
CLOUDFLARE_R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# ── Video Streaming — Mux (optional) ─────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# ── Email — Resend (optional) ────────────────────────────────
RESEND_API_KEY=re_...

# ── Cache — Upstash Redis (optional) ─────────────────────────
UPSTASH_REDIS_URL=https://...
UPSTASH_REDIS_TOKEN=
